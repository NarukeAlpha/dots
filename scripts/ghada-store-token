#!/usr/bin/env zsh
set -euo pipefail

restore_tty() {
  stty echo 2>/dev/null || true
}
trap restore_tty EXIT INT TERM

if [[ -t 0 ]]; then
  printf "Paste ghada GitHub token: " >&2
  stty -echo
  IFS= read -r token
  restore_tty
  printf "\n" >&2
else
  IFS= read -r token
fi

if [[ -z "$token" ]]; then
  printf "No token provided.\n" >&2
  exit 1
fi

security add-generic-password \
  -a ghada \
  -s ghada.github.com \
  -w "$token" \
  -U >/dev/null

printf "protocol=https\nhost=github.com\nusername=ghada\n\n" | git credential reject
printf "protocol=https\nhost=github.com\nusername=ghada\npassword=%s\n\n" "$token" | git credential approve

unset token
printf "Stored ghada token in macOS Keychain as service ghada.github.com.\n"
printf "Stored Git HTTPS credential for https://ghada@github.com.\n"
